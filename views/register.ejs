<%- include('partials/header') %>

<div class="main-content flex-grow-1 d-flex align-items-center justify-content-center" style="min-height: 90vh;">
  <div class="card card-premium shadow-lg p-4 col-md-6 my-5 mx-3">
    <div class="card-body">
      <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center card-icon-wrapper card-icon-success mx-auto mb-3">
          <i class="fa-solid fa-user-plus"></i>
        </div>
        <h3 class="fw-bold">Create Account</h3>
        <p class="text-muted">Register to join community celebrations</p>
      </div>

      <!-- Success & Error Alert Banners -->
      <div class="alert alert-danger d-none border-0 text-danger rounded-3 p-3 mb-4" id="errorAlert" style="background-color: rgba(239, 68, 68, 0.1);" role="alert"></div>
      <div class="alert alert-success d-none border-0 text-success rounded-3 p-3 mb-4" id="successAlert" style="background-color: rgba(16, 185, 129, 0.1);" role="alert"></div>

      <form id="registerForm">
        <!-- Name Input -->
        <div class="mb-3">
          <label for="name" class="form-label">Full Name</label>
          <div class="input-group">
            <span class="input-group-text border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
            <input type="text" class="form-control border-start-0 py-2.5 ps-1" id="name" placeholder="John Doe" required>
          </div>
        </div>

        <!-- Phone Input -->
        <div class="mb-3">
          <label for="phone" class="form-label">Phone Number</label>
          <div class="input-group">
            <span class="input-group-text border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
            <input type="text" class="form-control border-start-0 py-2.5 ps-1" id="phone" placeholder="555-0199" required>
          </div>
        </div>

        <!-- Email Input -->
        <div class="mb-3">
          <label for="email" class="form-label">Email Address</label>
          <div class="input-group">
            <span class="input-group-text border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
            <input type="email" class="form-control border-start-0 py-2.5 ps-1" id="email" placeholder="john@example.com" required>
          </div>
        </div>

        <!-- Password Input -->
        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <div class="input-group">
            <span class="input-group-text border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
            <input type="password" class="form-control border-start-0 py-2.5 ps-1" id="password" placeholder="Min 6 characters" required>
          </div>
        </div>

        <!-- User Role Choice -->
        <div class="mb-3">
          <label for="role" class="form-label">Register As</label>
          <div class="input-group">
            <span class="input-group-text border-end-0"><i class="fa-solid fa-id-card text-muted"></i></span>
            <select class="form-select border-start-0 py-2.5 ps-1" id="role" required>
              <option value="Contributor" selected>Contributor (Donor)</option>
              <option value="Volunteer">Volunteer</option>
              <option value="Vendor">Vendor (Service Provider)</option>
              <option value="Organizer">Organizer (Staff)</option>
            </select>
          </div>
        </div>

        <!-- Vendor Specific Fields (shown dynamically) -->
        <div class="mb-4 d-none" id="vendorFields">
          <label for="service_type" class="form-label">Service Type</label>
          <div class="input-group">
            <span class="input-group-text border-end-0"><i class="fa-solid fa-handshake-angle text-muted"></i></span>
            <input type="text" class="form-control border-start-0 py-2.5 ps-1" id="service_type" placeholder="e.g. Catering, Audio Setup, Stage Setup">
          </div>
        </div>

        <!-- Register Button -->
        <button type="submit" class="btn btn-accent-custom w-100 py-3 fw-semibold mb-4 fs-6">
          <i class="fa-solid fa-user-plus me-2"></i>Sign Up
        </button>
      </form>

      <div class="text-center">
        <span class="text-muted">Already have an account? </span>
        <a href="/login" class="text-primary fw-bold text-decoration-none hover-underline">Login</a>
      </div>
    </div>
  </div>
</div>

<script>
  // Dynamically show service type field when vendor is selected
  document.getElementById('role').addEventListener('change', function() {
    const vendorFields = document.getElementById('vendorFields');
    if (this.value === 'Vendor') {
      vendorFields.classList.remove('d-none');
    } else {
      vendorFields.classList.add('d-none');
    }
  });

  // Pre-select role if passed in the query parameter
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const role = params.get('role');
    if (role) {
      const select = document.getElementById('role');
      select.value = role;
      // Trigger change event to show or hide vendor specific inputs
      select.dispatchEvent(new Event('change'));
    }
  });

  // Handle register submit via Fetch API
  document.getElementById('registerForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const name = document.getElementById('name').value;
    const phone = document.getElementById('phone').value;
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const role = document.getElementById('role').value;
    const service_type = document.getElementById('service_type').value;

    const errorAlert = document.getElementById('errorAlert');
    const successAlert = document.getElementById('successAlert');

    errorAlert.classList.add('d-none');
    successAlert.classList.add('d-none');

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone, email, password, role, service_type })
      });

      const data = await res.json();
      if (data.success) {
        successAlert.textContent = data.message;
        successAlert.classList.remove('d-none');
        setTimeout(() => { window.location.href = '/login'; }, 2000);
      } else {
        errorAlert.textContent = data.message || 'Registration failed.';
        errorAlert.classList.remove('d-none');
      }
    } catch (err) {
      errorAlert.textContent = 'Server connection error. Please try again.';
      errorAlert.classList.remove('d-none');
    }
  });
</script>

<%- include('partials/footer') %>
