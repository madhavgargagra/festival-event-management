<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="main-content flex-grow-1">
  <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h2 class="fw-bold"><i class="fa-solid fa-truck-ramp-box text-primary me-2"></i>Vendor Compliance & Billing Panel</h2>
    <span class="badge badge-status <%= profile.compliance_status === 'Verified' ? 'badge-verified' : (profile.compliance_status === 'Flagged' ? 'badge-flagged' : 'badge-pending') %> py-2 px-3 fs-6">
      Compliance: <%= profile.compliance_status %>
    </span>
  </div>

  <div class="row">
    <!-- Left Column: Profile and Docs Upload Form -->
    <div class="col-md-5 mb-4">
      <div class="card card-premium shadow mb-4">
        <div class="card-header-premium"><i class="fa-solid fa-id-card-clip me-2"></i>Vendor details</div>
        <div class="card-body">
          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Company Name:</span>
              <strong><%= profile.name %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Primary Service:</span>
              <strong><%= profile.service_type %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Performance Score:</span>
              <strong class="text-primary"><%= parseFloat(profile.past_performance).toFixed(2) %> / 5.00</strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Address:</span>
              <strong><%= profile.address || 'Not specified' %></strong>
            </li>
          </ul>
        </div>
      </div>

      <div class="card card-premium shadow">
        <div class="card-header-premium"><i class="fa-solid fa-file-invoice me-2"></i>Submit Compliance Documents</div>
        <div class="card-body">
          <form id="uploadComplianceForm" enctype="multipart/form-data">
            <input type="hidden" name="uploadType" value="vendor_doc">
            
            <div class="mb-3">
              <label for="address" class="form-label small fw-bold">Company Address</label>
              <input type="text" class="form-control" name="address" id="address" value="<%= profile.address || '' %>" placeholder="123 Business Way, Suite A" required>
            </div>

            <div class="mb-4">
              <label for="compFile" class="form-label small fw-bold">Upload Compliance Doc (Licenses/GST File, PDF/Image Max 5MB)</label>
              <input class="form-control" type="file" name="compliance" id="compFile" required>
              <% if (profile.compliance_info) { %>
                <div class="mt-2 text-success small">
                  <i class="fa-solid fa-circle-check me-1"></i>Active document: <a href="<%= profile.compliance_info %>" target="_blank">View File</a>
                </div>
              <% } %>
            </div>

            <button type="submit" class="btn btn-primary-custom w-100 py-2"><i class="fa-solid fa-cloud-arrow-up me-2"></i>Submit Verification</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Right Column: Billing & Expense Logs -->
    <div class="col-md-7">
      <div class="card card-premium shadow">
        <div class="card-header-premium"><i class="fa-solid fa-money-bill-transfer me-2"></i>Linked Invoices & Bills</div>
        <div class="card-body p-0 table-responsive">
          <table class="table table-hover align-middle m-0 text-nowrap">
            <thead class="table-light">
              <tr>
                <th>Bill ID</th>
                <th>Event</th>
                <th>Amount</th>
                <th>Approval</th>
                <th>Payment</th>
                <th>Invoice</th>
              </tr>
            </thead>
            <tbody>
              <% if (expenses && expenses.length > 0) { %>
                <% expenses.forEach(exp => { %>
                  <tr>
                    <td>#<%= exp.expense_id %></td>
                    <td><strong><%= exp.Event ? exp.Event.name : 'N/A' %></strong></td>
                    <td class="fw-bold text-danger">$<%= parseFloat(exp.amount).toFixed(2) %></td>
                    <td>
                      <span class="badge <%= exp.approval_status === 'Approved' ? 'bg-success' : 'bg-secondary' %>">
                        <%= exp.approval_status %>
                      </span>
                    </td>
                    <td>
                      <span class="badge <%= exp.payment_status === 'Paid' ? 'bg-success' : 'bg-warning text-dark' %>">
                        <%= exp.payment_status %>
                      </span>
                    </td>
                    <td>
                      <% if (exp.invoice_path) { %>
                        <a href="<%= exp.invoice_path %>" target="_blank" class="btn btn-sm btn-link"><i class="fa-solid fa-eye"></i> View</a>
                      <% } else { %>
                        <form onsubmit="uploadBillInvoice(event, '<%= exp.expense_id %>')" enctype="multipart/form-data">
                          <input type="hidden" name="uploadType" value="invoice">
                          <div class="input-group input-group-sm" style="max-width: 220px;">
                            <input type="file" class="form-control" name="invoice" required>
                            <button class="btn btn-primary-custom" type="submit">Upload</button>
                          </div>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-5 text-muted">No bill transactions linked to your profile.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // 1. Submit compliance documents form
  document.getElementById('uploadComplianceForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);

    try {
      const res = await fetch('/api/vendors/profile/compliance', {
        method: 'POST',
        body: formData
      });
      const data = await res.json();
      if (data.success) {
        alert(data.message);
        window.location.reload();
      } else {
        alert(data.message);
      }
    } catch(err) {
      alert('Error uploading document file.');
    }
  });

  // 2. Submit invoice file for specific bill/expense
  async function uploadBillInvoice(e, expId) {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);

    try {
      const res = await fetch(`/api/expenses/${expId}`, {
        method: 'PUT',
        body: formData
      });
      const data = await res.json();
      if (data.success) {
        alert('Invoice uploaded successfully!');
        window.location.reload();
      } else {
        alert(data.message);
      }
    } catch(err) {
      alert('Error uploading invoice file.');
    }
  }
</script>

<%- include('partials/footer') %>
