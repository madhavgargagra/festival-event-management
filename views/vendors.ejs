<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="main-content flex-grow-1">
  <h2 class="fw-bold mb-4"><i class="fa-solid fa-truck-ramp-box text-primary me-2"></i>Active Service Providers & Vendors</h2>
  
  <div class="row">
    <% if (vendors && vendors.length > 0) { %>
      <% vendors.forEach(ven => { %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card card-premium shadow h-100">
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <h4 class="fw-bold text-secondary m-0"><%= ven.name %></h4>
                <span class="badge badge-status <%= ven.compliance_status === 'Verified' ? 'badge-verified' : (ven.compliance_status === 'Flagged' ? 'badge-flagged' : 'badge-pending') %>">
                  <%= ven.compliance_status %>
                </span>
              </div>
              
              <ul class="list-group list-group-flush small bg-transparent flex-grow-1">
                <li class="list-group-item bg-transparent px-0"><span class="text-muted">Primary Service:</span> <strong><%= ven.service_type %></strong></li>
                <li class="list-group-item bg-transparent px-0"><span class="text-muted">Contact phone:</span> <strong><%= ven.phone || 'N/A' %></strong></li>
                <li class="list-group-item bg-transparent px-0"><span class="text-muted">Address location:</span> <strong class="text-truncate d-inline-block" style="max-width: 200px;"><%= ven.address || 'N/A' %></strong></li>
                <li class="list-group-item bg-transparent px-0 d-flex justify-content-between">
                  <span class="text-muted">Performance:</span>
                  <span class="text-warning fw-bold"><i class="fa-solid fa-star me-1"></i><%= parseFloat(ven.past_performance).toFixed(2) %> / 5.00</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5 text-muted">
        <i class="fa-solid fa-ban fa-3x mb-3 text-opacity-25"></i>
        <h5>No vendors registered.</h5>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
