<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="main-content flex-grow-1">
  <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h2 class="fw-bold"><i class="fa-solid fa-circle-dollar-to-slot text-primary me-2"></i>Contributor Panel</h2>
    <button class="btn btn-primary-custom" data-bs-toggle="modal" data-bs-target="#newContributionModal"><i class="fa-solid fa-gift me-2"></i>Make a Contribution</button>
  </div>

  <div class="row mb-4">
    <!-- Profile Info Card -->
    <div class="col-md-4 mb-4">
      <div class="card card-premium shadow h-100">
        <div class="card-header-premium"><i class="fa-solid fa-id-card me-2"></i>My Donor Profile</div>
        <div class="card-body">
          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Name:</span>
              <strong><%= profile.name %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Type:</span>
              <strong><%= profile.contributor_type %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Email:</span>
              <strong><%= profile.email %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between px-0">
              <span class="text-muted">Total Donated:</span>
              <strong class="text-success">$<%= totalAmount.toFixed(2) %></strong>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Impact Summary metric card -->
    <div class="col-md-8 mb-4">
      <div class="card card-premium shadow h-100 p-4 d-flex flex-column justify-content-center">
        <h4 class="fw-bold mb-3"><i class="fa-solid fa-chart-line text-accent me-2"></i>Our Impact Summary</h4>
        <p class="text-muted">Your contributions are allocated directly to event logistics, sound setups, and artist hospitality. Check the Allocation table below to see which events your donations are currently supporting.</p>
        <div class="d-flex align-items-center mt-3">
          <div class="me-4 text-center">
            <div class="h3 fw-bold text-primary m-0"><%= contributions.length %></div>
            <div class="text-muted small text-uppercase">Contributions</div>
          </div>
          <div class="border-start border-secondary border-opacity-25 h-100 mx-3" style="min-height: 40px;"></div>
          <div class="text-center">
            <div class="h3 fw-bold text-success m-0">$<%= totalAmount.toFixed(2) %></div>
            <div class="text-muted small text-uppercase">Total Contributed</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Contributions log tabs -->
  <div class="card card-premium mb-4">
    <div class="card-header-premium"><i class="fa-solid fa-clock-rotate-left me-2"></i>My Contributions Log</div>
    <div class="card-body p-0 table-responsive">
      <table class="table table-hover align-middle m-0">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Festival</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Specification/Description</th>
          </tr>
        </thead>
        <tbody>
          <% if (contributions && contributions.length > 0) { %>
            <% contributions.forEach(con => { %>
              <tr>
                <td>#<%= con.contribution_id %></td>
                <td><%= con.Festival ? con.Festival.name : 'General Fund' %></td>
                <td><span class="badge bg-info text-dark"><%= con.contribution_type %></span></td>
                <td class="fw-bold text-success">$<%= parseFloat(con.amount || 0).toFixed(2) %></td>
                <td><%= con.date %></td>
                <td><small class="text-muted"><%= con.description || 'N/A' %></small></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center py-5 text-muted">You have not submitted any contributions yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Allocation Tracking Pane -->
  <div class="card card-premium shadow">
    <div class="card-header-premium"><i class="fa-solid fa-map-location-dot me-2"></i>Allocation Tracking</div>
    <div class="card-body p-0 table-responsive">
      <table class="table table-striped align-middle m-0 text-nowrap">
        <thead class="table-light">
          <tr>
            <th>Allocation ID</th>
            <th>Contribution Source</th>
            <th>Target Event</th>
            <th>Allocated Item</th>
            <th>Allocated Amount</th>
            <th>Allocation Date</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (allocations && allocations.length > 0) { %>
            <% allocations.forEach(alloc => { %>
              <tr>
                <td>#<%= alloc.allocation_id %></td>
                <td>Contribution #<%= alloc.contribution_id %></td>
                <td><strong><%= alloc.Event ? alloc.Event.name : 'N/A' %></strong></td>
                <td><%= alloc.allocated_item %></td>
                <td class="fw-bold text-success">$<%= parseFloat(alloc.allocated_amount || 0).toFixed(2) %></td>
                <td><%= alloc.allocation_date %></td>
                <td>
                  <span class="badge <%= alloc.status === 'Allocated' ? 'bg-success' : 'bg-warning text-dark' %>">
                    <%= alloc.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-4 text-muted">No allocations found for your contributions yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal: Make a Contribution -->
<div class="modal fade" id="newContributionModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form id="newContributionForm" class="modal-content modal-content-premium">
      <div class="modal-header modal-header-premium">
        <h5 class="modal-title fw-bold">Submit Contribution</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body modal-body-premium">
        <div class="mb-3">
          <label for="conType" class="form-label fw-semibold">Contribution Type</label>
          <select class="form-select" id="conType" required>
            <option value="Cash" selected>Cash (Monetary)</option>
            <option value="In-Kind">In-Kind (Equipment/Supplies)</option>
            <option value="Service">Service (Professional Help)</option>
          </select>
        </div>

        <div class="mb-3" id="cashAmountField">
          <label for="conAmount" class="form-label fw-semibold">Amount ($)</label>
          <input type="number" step="0.01" class="form-control" id="conAmount" placeholder="0.00" value="0.00">
        </div>

        <div class="mb-3">
          <label for="conDesc" class="form-label fw-semibold">Description / Specification</label>
          <textarea class="form-control" id="conDesc" rows="3" placeholder="Specify items or details about the services you wish to donate..." required></textarea>
        </div>
      </div>
      <div class="modal-footer border-top-0">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary-custom">Submit Donation</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Dynamically toggle amount validation based on donation type choice
  document.getElementById('conType').addEventListener('change', function() {
    const amtField = document.getElementById('cashAmountField');
    if (this.value === 'Cash') {
      amtField.classList.remove('d-none');
    } else {
      amtField.classList.add('d-none');
      document.getElementById('conAmount').value = '0.00';
    }
  });

  // Submit contribution AJAX Fetch trigger
  document.getElementById('newContributionForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const contribution_type = document.getElementById('conType').value;
    const amount = document.getElementById('conAmount').value;
    const description = document.getElementById('conDesc').value;

    try {
      const res = await fetch('/api/contributors/contributions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contribution_type, amount, description })
      });
      const data = await res.json();
      if (data.success) {
        alert(data.message);
        window.location.reload();
      } else {
        alert(data.message);
      }
    } catch(err) {
      alert('Error recording contribution.');
    }
  });
</script>

<%- include('partials/footer') %>
