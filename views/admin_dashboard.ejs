  // 6. Create Event API trigger
  document.getElementById('createEventForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const festival_id = document.getElementById('evtFest').value;
    const name = document.getElementById('evtName').value;
    const description = document.getElementById('evtDesc').value;
    const location = document.getElementById('evtLoc').value;
    const dateStr = document.getElementById('evtDate').value;
    const budget_estimate = document.getElementById('evtBudget').value;

    if (!dateStr) {
      Toast.fire({
        icon: 'error',
        title: 'Please enter a valid Date & Time'
      });
      return;
    }
    const parsedDate = new Date(dateStr);
    if (isNaN(parsedDate.getTime())) {
      Toast.fire({
        icon: 'error',
        title: 'Invalid Date & Time selection.'
      });
      return;
    }

    try {
      const res = await fetch('/api/events', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ festival_id, name, description, location, date: parsedDate.toISOString(), budget_estimate })
      });
      const data = await res.json();
      if (data.success) {
        Toast.fire({
          icon: 'success',
          title: 'Event created successfully!'
        });
        setTimeout(() => window.location.reload(), 1500);
      } else {
        Toast.fire({
          icon: 'error',
          title: data.message || 'Error occurred.'
        });
      }
    } catch(err) {
      Toast.fire({
        icon: 'error',
        title: 'Error creating event.'
      });
    }
  });

  // Audit Diff Viewer Trigger Logic
  document.querySelectorAll('.btn-audit-diff').forEach(btn => {
    btn.addEventListener('click', function() {
      const entityType = this.getAttribute('data-entity');
      const entityId = this.getAttribute('data-entity-id');
      const action = this.getAttribute('data-action');
      
      let oldVal = {};
      let newVal = {};
      try {
        oldVal = JSON.parse(this.getAttribute('data-old') || '{}');
      } catch(e) { console.error('Failed to parse old value JSON:', e); }
      try {
        newVal = JSON.parse(this.getAttribute('data-new') || '{}');
      } catch(e) { console.error('Failed to parse new value JSON:', e); }
      
      document.getElementById('diffEntityType').textContent = entityType;
      document.getElementById('diffEntityId').textContent = entityId;
      
      const badge = document.getElementById('diffAction');
      badge.textContent = action;
      badge.className = 'badge ' + (action === 'CREATE' ? 'bg-success' : (action === 'UPDATE' ? 'bg-warning text-dark' : 'bg-danger'));
      
      const allKeys = new Set([...Object.keys(oldVal), ...Object.keys(newVal)]);
      const tbody = document.getElementById('auditDiffTableBody');
      tbody.innerHTML = '';
      
      if (allKeys.size === 0) {
        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">No details recorded for this action.</td></tr>';
      } else {
        allKeys.forEach(key => {
          if (key === 'password' || key === 'password_hash') return;
          
          const oldRaw = oldVal[key];
          const newRaw = newVal[key];
          
          const oldDisplay = oldRaw !== undefined ? (typeof oldRaw === 'object' ? JSON.stringify(oldRaw) : oldRaw) : '';
          const newDisplay = newRaw !== undefined ? (typeof newRaw === 'object' ? JSON.stringify(newRaw) : newRaw) : '';
          
          const tr = document.createElement('tr');
          
          const tdKey = document.createElement('td');
          tdKey.innerHTML = `<code>${key}</code>`;
          
          const tdOld = document.createElement('td');
          const tdNew = document.createElement('td');
          
          if (action === 'CREATE') {
            tdOld.innerHTML = '<span class="text-muted small">None</span>';
            tdNew.innerHTML = `<span class="badge bg-success-subtle text-success p-2 border border-success-subtle">${newDisplay}</span>`;
          } else if (action === 'DELETE') {
            tdOld.innerHTML = `<span class="badge bg-danger-subtle text-danger p-2 border border-danger-subtle" style="text-decoration: line-through;">${oldDisplay}</span>`;
            tdNew.innerHTML = '<span class="text-muted small">None</span>';
          } else {
            if (oldDisplay === newDisplay) {
              tdOld.textContent = oldDisplay;
              tdNew.textContent = newDisplay;
            } else {
              tdOld.innerHTML = `<span class="text-danger border-bottom border-danger" style="text-decoration: line-through;">${oldDisplay}</span>`;
              tdNew.innerHTML = `<span class="text-success fw-bold border-bottom border-success bg-success bg-opacity-10 px-1 rounded">${newDisplay}</span>`;
            }
          }
          
          tr.appendChild(tdKey);
          tr.appendChild(tdOld);
          tr.appendChild(tdNew);
          tbody.appendChild(tr);
        });
      }
      
      bootstrap.Modal.getOrCreateInstance(document.getElementById('auditDiffModal')).show();
    });
  });

  // SQL Sandbox execution AJAX trigger
  document.getElementById('btnRunSandboxQuery').addEventListener('click', async function() {
    const sql = document.getElementById('sandboxQueryInput').value.trim();
    if (!sql) {
      Toast.fire({
        icon: 'warning',
        title: 'Please enter an SQL query first.'
      });
      return;
    }

    const outputDiv = document.getElementById('sandboxConsoleOutput');
    const timerBadge = document.getElementById('sandboxTimerBadge');
    
    outputDiv.style.display = 'block';
    outputDiv.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>Running query benchmarks...</div>';
    timerBadge.classList.add('d-none');

    try {
      const res = await fetch('/api/audit/sandbox', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sql })
      });
      const data = await res.json();
      
      if (data.success) {
        timerBadge.classList.remove('d-none');
        document.getElementById('sandboxExecutionTime').textContent = data.executionTimeMs;

        const results = data.results;
        if (results.length === 0) {
          outputDiv.innerHTML = '<div class="text-muted p-2"><i class="fa-solid fa-circle-info me-2"></i>Query executed successfully, but returned 0 rows.</div>';
          return;
        }

        const headers = Object.keys(results[0]);
        let tableHtml = '<table class="table table-hover table-striped align-middle m-0 small">';
        tableHtml += '<thead class="table-dark"><tr>';
        headers.forEach(h => {
          tableHtml += `<th>${h}</th>`;
        });
        tableHtml += '</tr></thead><tbody>';
        
        results.forEach(row => {
          tableHtml += '<tr>';
          headers.forEach(h => {
            const val = row[h];
            tableHtml += `<td>${val !== null ? (typeof val === 'object' ? JSON.stringify(val) : val) : '<span class="text-muted">NULL</span>'}</td>`;
          });
          tableHtml += '</tr>';
        });
        tableHtml += '</tbody></table>';

        outputDiv.innerHTML = tableHtml;
      } else {
        outputDiv.innerHTML = `
          <div class="p-3 rounded font-monospace" style="font-family: monospace; font-size: 0.9rem; line-height: 1.5; color: #ef4444 !important; background-color: #0b0f19 !important;">
            <div class="fw-bold mb-2"><i class="fa-solid fa-circle-xmark me-2"></i>Database Error / Constraint Violation</div>
            <div>${data.message}</div>
          </div>
        `;
      }
    } catch(err) {
      outputDiv.innerHTML = `<div class="alert alert-danger m-0">Failed to connect to the SQL sandbox API: ${err.message}</div>`;
    }
  });

  // Client-side tab navigation helper
  window.showAdminTab = function(tabId) {
    const tabEl = document.querySelector(`#adminTabs button[data-bs-target="#${tabId}"]`);
    if (tabEl) {
      const tab = new bootstrap.Tab(tabEl);
      tab.show();
      document.getElementById('adminTabs').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  };
</script>

