<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Financial Report - <%= event.name %></title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome Icons -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8fafc;
      color: #0f172a;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      padding: 40px 20px;
    }
    .report-card {
      background-color: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
      padding: 40px;
      max-width: 900px;
      margin: 0 auto;
    }
    .badge-status {
      padding: 6px 12px;
      border-radius: 50px;
      font-weight: 600;
      font-size: 0.8rem;
    }
    /* Printing Overrides */
    @media print {
      body {
        background-color: #ffffff !important;
        color: #000000 !important;
        padding: 0 !important;
      }
      .report-card {
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        max-width: 100% !important;
      }
      .no-print {
        display: none !important;
      }
      .table th {
        background-color: #f1f5f9 !important;
        color: #000000 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>

  <div class="container no-print text-center mb-4">
    <button class="btn btn-primary btn-lg shadow-sm px-4 py-2 me-2" onclick="window.print()">
      <i class="fa-solid fa-print me-2"></i>Print / Save as PDF
    </button>
    <button class="btn btn-outline-secondary btn-lg px-4 py-2" onclick="window.close()">
      <i class="fa-solid fa-xmark me-2"></i>Close Tab
    </button>
  </div>

  <div class="report-card">
    <!-- Report Header -->
    <div class="d-flex justify-content-between align-items-center border-bottom pb-4 mb-4">
      <div>
        <h2 class="fw-bold mb-1 text-primary"><i class="fa-solid fa-masks-theater me-2"></i>FestSystem</h2>
        <p class="text-muted m-0 small">Official Event Financial Statement & Invoice Summary</p>
      </div>
      <div class="text-end">
        <h5 class="fw-bold m-0">INVOICE REPORT</h5>
        <p class="text-muted m-0 small">Generated: <%= new Date().toLocaleDateString() %></p>
      </div>
    </div>

    <!-- Event Info Grid -->
    <div class="row mb-5">
      <div class="col-md-6 mb-3">
        <h6 class="text-uppercase text-muted fw-bold small mb-2">Event Parameters</h6>
        <h4 class="fw-bold mb-2"><%= event.name %></h4>
        <p class="text-muted mb-2 small"><%= event.description || 'No description provided.' %></p>
        <div class="small">
          <div><strong>Festival Umbrella:</strong> <%= event.Festival ? event.Festival.name : 'Independent' %></div>
          <div><strong>Venue:</strong> <%= event.location %></div>
          <div><strong>Scheduled Date:</strong> <%= new Date(event.date).toLocaleString() %></div>
        </div>
      </div>
      <div class="col-md-6 mb-3 text-md-end">
        <h6 class="text-uppercase text-muted fw-bold small mb-2">Organizer support</h6>
        <h5 class="fw-bold mb-1"><%= event.Organizer ? event.Organizer.name : 'System Administrator' %></h5>
        <p class="text-muted m-0 small"><%= event.Organizer ? event.Organizer.email : 'admin@fest.com' %></p>
        <p class="text-muted m-0 small"><%= event.Organizer ? event.Organizer.phone : '555-0100' %></p>
      </div>
    </div>

    <!-- Financial Metrics Panel -->
    <% 
      const totalBudget = parseFloat(event.budget_estimate || 0);
      const totalAllocated = allocations.reduce((sum, a) => sum + parseFloat(a.allocated_amount || 0), 0);
      const totalExpended = expenses.reduce((sum, e) => sum + (e.approval_status === 'Approved' ? parseFloat(e.amount || 0) : 0), 0);
      const netBalance = totalAllocated - totalExpended;
    %>
    <div class="row g-3 mb-5">
      <div class="col-sm-3">
        <div class="border rounded p-3 text-center bg-light">
          <div class="text-muted small fw-semibold text-uppercase">Budget Estimate</div>
          <h4 class="fw-bold mt-1 text-dark">$<%= totalBudget.toFixed(2) %></h4>
        </div>
      </div>
      <div class="col-sm-3">
        <div class="border rounded p-3 text-center bg-light">
          <div class="text-muted small fw-semibold text-uppercase">Acquired Funds</div>
          <h4 class="fw-bold mt-1 text-success">$<%= totalAllocated.toFixed(2) %></h4>
        </div>
      </div>
      <div class="col-sm-3">
        <div class="border rounded p-3 text-center bg-light">
          <div class="text-muted small fw-semibold text-uppercase">Approved Expenses</div>
          <h4 class="fw-bold mt-1 text-danger">$<%= totalExpended.toFixed(2) %></h4>
        </div>
      </div>
      <div class="col-sm-3">
        <div class="border rounded p-3 text-center bg-light">
          <div class="text-muted small fw-semibold text-uppercase">Net Balance</div>
          <h4 class="fw-bold mt-1 <%= netBalance >= 0 ? 'text-primary' : 'text-warning' %>">$<%= netBalance.toFixed(2) %></h4>
        </div>
      </div>
    </div>

    <!-- Allocations Detail Section -->
    <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="fa-solid fa-circle-dollar-to-slot text-success me-2"></i>Cash Contribution Allocations</h5>
    <div class="table-responsive mb-5">
      <table class="table table-bordered align-middle small">
        <thead class="table-light">
          <tr>
            <th>Source ID</th>
            <th>Contributor Name</th>
            <th>Allocation Date</th>
            <th>Item Specification</th>
            <th class="text-end">Allocated Amount</th>
          </tr>
        </thead>
        <tbody>
          <% if (allocations.length > 0) { %>
            <% allocations.forEach(a => { %>
              <tr>
                <td>#<%= a.contribution_id %></td>
                <td><strong><%= a.Contribution && a.Contribution.Contributor ? a.Contribution.Contributor.name : 'Anon Contributor' %></strong></td>
                <td><%= a.allocation_date %></td>
                <td><%= a.allocated_item %></td>
                <td class="text-end fw-bold text-success">$<%= parseFloat(a.allocated_amount || 0).toFixed(2) %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center py-3 text-muted">No allocations recorded for this event.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Expenditures Detail Section -->
    <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="fa-solid fa-receipt text-danger me-2"></i>Event Expenditure & Expense Receipts</h5>
    <div class="table-responsive mb-4">
      <table class="table table-bordered align-middle small">
        <thead class="table-light">
          <tr>
            <th>Expense ID</th>
            <th>Description</th>
            <th>Category</th>
            <th>Vendor Link</th>
            <th>Date</th>
            <th>Status</th>
            <th class="text-end">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% if (expenses.length > 0) { %>
            <% expenses.forEach(e => { %>
              <tr>
                <td>#<%= e.expense_id %></td>
                <td><strong><%= e.description %></strong></td>
                <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-20"><%= e.expense_type %></span></td>
                <td><%= e.Vendor ? e.Vendor.name : 'No Vendor Link' %></td>
                <td><%= e.expense_date %></td>
                <td>
                  <span class="badge bg-opacity-10 <%= e.approval_status === 'Approved' ? 'bg-success text-success' : (e.approval_status === 'Pending' ? 'bg-warning text-dark' : 'bg-danger text-danger') %>">
                    <%= e.approval_status %>
                  </span>
                </td>
                <td class="text-end fw-bold text-danger">$<%= parseFloat(e.amount || 0).toFixed(2) %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-3 text-muted">No expenses recorded for this event.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Signatures -->
    <div class="row mt-5 pt-4 border-top">
      <div class="col-6">
        <div class="border-bottom w-75 mb-2 mt-4"></div>
        <p class="small text-muted m-0">Event Coordinator Signature</p>
      </div>
      <div class="col-6 text-end d-flex flex-column align-items-end">
        <div class="border-bottom w-75 mb-2 mt-4"></div>
        <p class="small text-muted m-0">Finance Officer Approval Stamp</p>
      </div>
    </div>

  </div>

</body>
</html>
